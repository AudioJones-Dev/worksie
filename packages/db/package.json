{
  "name": "@worksie/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "migrate": "echo 'Phase 1: no migrations yet. Use supabase db reset once Phase 2 schema lands.'",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@worksie/domain": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@worksie/config": "workspace:*",
    "drizzle-kit": "^0.28.1",
    "eslint": "^8.57.1",
    "typescript": "^5.6.3"
  }
}
