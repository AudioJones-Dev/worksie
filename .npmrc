engine-strict=false
auto-install-peers=true
strict-peer-dependencies=false

# ESLint resolves a shareable config's plugins relative to the *consuming*
# package. Under pnpm's isolated node_modules the typescript-eslint parser and
# plugin (declared by @worksie/config) are otherwise unreachable from packages
# that extend the preset, so `turbo run lint` fails. Hoist them to the root so
# every workspace package can resolve them.
public-hoist-pattern[]=@typescript-eslint/*
