generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DISPATCHER
  CONTRACTOR
  CLIENT
}

enum JobStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETE
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  clients        Client[]
  sites          Site[]
  templates      JobTemplate[]
  jobs           Job[]
  invoices       Invoice[]
  billingBatches WeeklyBillingBatch[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  displayName    String
  role           UserRole @default(CONTRACTOR)

  // Auth persistence fields intentionally mirror the OpenAPI AuthSession contract.
  passwordHash        String?
  refreshTokenHash    String?
  refreshTokenExpires DateTime?
  lastLoginAt         DateTime?
  sessionVersion      Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments  MilestoneAssignment[]

  @@unique([organizationId, email])
  @@unique([organizationId, id])
  @@index([organizationId])
}

model Client {
  id             String @id @default(cuid())
  organizationId String
  name           String
  billingEmail   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sites        Site[]
  jobs         Job[]
  invoices     Invoice[]

  @@unique([organizationId, id])
  @@index([organizationId])
}

model Site {
  id             String @id @default(cuid())
  organizationId String
  clientId       String
  name           String
  addressLine1   String
  city           String
  region         String
  postalCode     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [organizationId, clientId], references: [organizationId, id], onDelete: Restrict)
  jobs         Job[]

  @@unique([organizationId, id])
  @@index([organizationId, clientId])
}

model JobTemplate {
  id             String @id @default(cuid())
  organizationId String
  name           String
  active         Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  milestones   TemplateMilestone[]
  jobs         Job[]

  @@unique([organizationId, id])
  @@index([organizationId])
}

model TemplateMilestone {
  id             String @id @default(cuid())
  organizationId String
  templateId     String
  name           String
  sortOrder      Int

  template JobTemplate @relation(fields: [organizationId, templateId], references: [organizationId, id], onDelete: Cascade)
  jobMilestones JobMilestone[]

  @@unique([organizationId, id])
  @@unique([organizationId, templateId, sortOrder])
  @@index([organizationId, templateId])
}

model Job {
  id             String    @id @default(cuid())
  organizationId String
  templateId     String
  clientId       String
  siteId         String
  status         JobStatus @default(DRAFT)
  scheduledFor   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     JobTemplate  @relation(fields: [organizationId, templateId], references: [organizationId, id], onDelete: Restrict)
  client       Client       @relation(fields: [organizationId, clientId], references: [organizationId, id], onDelete: Restrict)
  site         Site         @relation(fields: [organizationId, siteId], references: [organizationId, id], onDelete: Restrict)
  milestones   JobMilestone[]
  invoices     Invoice[]

  @@unique([organizationId, id])
  @@index([organizationId, templateId])
  @@index([organizationId, clientId])
  @@index([organizationId, siteId])
}

model JobMilestone {
  id                  String @id @default(cuid())
  organizationId      String
  jobId               String
  templateMilestoneId String
  name                String
  sortOrder           Int

  job Job @relation(fields: [organizationId, jobId], references: [organizationId, id], onDelete: Cascade)
  templateMilestone TemplateMilestone @relation(fields: [organizationId, templateMilestoneId], references: [organizationId, id], onDelete: Restrict)
  assignments MilestoneAssignment[]

  @@unique([organizationId, id])
  @@unique([organizationId, jobId, sortOrder])
  @@index([organizationId, templateMilestoneId])
}

model MilestoneAssignment {
  id             String @id @default(cuid())
  organizationId String
  milestoneId    String
  contractorId   String
  splitPercentage Decimal

  milestone  JobMilestone @relation(fields: [organizationId, milestoneId], references: [organizationId, id], onDelete: Cascade)
  contractor User         @relation(fields: [organizationId, contractorId], references: [organizationId, id], onDelete: Restrict)

  @@unique([organizationId, milestoneId, contractorId])
  @@index([organizationId, milestoneId])
}

model WeeklyBillingBatch {
  id             String   @id @default(cuid())
  organizationId String
  weekStartsOn   DateTime
  weekEndsOn     DateTime
  closedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@unique([organizationId, weekStartsOn])
  @@unique([organizationId, id])
  @@index([organizationId])
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  jobId          String
  clientId       String
  billingBatchId String?
  invoiceNumber  String
  status         InvoiceStatus @default(DRAFT)
  totalCents     Int
  issuedAt       DateTime?
  paidAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job          Job                 @relation(fields: [organizationId, jobId], references: [organizationId, id], onDelete: Restrict)
  client       Client              @relation(fields: [organizationId, clientId], references: [organizationId, id], onDelete: Restrict)
  billingBatch WeeklyBillingBatch? @relation(fields: [organizationId, billingBatchId], references: [organizationId, id], onDelete: Restrict)

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, billingBatchId])
  @@index([organizationId, clientId])
  @@index([organizationId, jobId])
}
